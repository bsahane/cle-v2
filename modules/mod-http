## ** mod-http: HTTP/API testing utilities **
#* version: 2026-04-06

command -v curl >/dev/null 2>&1 || return

## `GET <url> [headers...]` - HTTP GET with timing
GET () {
	local URL=${1:?Usage: GET <url> [header:value ...]}
	shift
	local HARGS=""
	for H in "$@"; do HARGS="$HARGS -H '$H'"; done
	eval curl -sS -w '\n--- %{http_code} | %{time_total}s | %{size_download}B ---\n' $HARGS "$URL"
}

## `POST <url> <data|@file> [headers...]` - HTTP POST with timing
POST () {
	local URL=${1:?Usage: POST <url> <data|@file> [header:value ...]}
	local DATA=${2:?Usage: POST <url> <data|@file>}
	shift 2
	local HARGS="-H 'Content-Type: application/json'"
	for H in "$@"; do HARGS="$HARGS -H '$H'"; done
	eval curl -sS -X POST -d "'$DATA'" -w '\n--- %{http_code} | %{time_total}s ---\n' $HARGS "$URL"
}

