## `lsmtpcheck <host> [port]` - verify SMTP connectivity
lsmtpcheck () {
	local host=$1 port=${2:-25}
	[ -z "$host" ] && { echo "Usage: lsmtpcheck <host> [port]"; return 1; }

	echo "Connecting to $host:$port..."
	echo "--------------------------------------"
	local response
	response=$(echo -e "QUIT" | nc -w 5 "$host" "$port" 2>/dev/null)
	if [ -z "$response" ]; then
		echo "No response from $host:$port"
	else
		echo "SMTP Banner:"
		echo "$response"
	fi
	echo "--------------------------------------"
}
