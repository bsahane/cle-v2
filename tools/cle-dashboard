#!/usr/bin/env bash
#
# CLE Dashboard - nmtui-style TUI host monitoring
# Pure bash + tput - no external dependencies
#
# Usage: cle-dashboard [host:port ...]
# Keys:  1-7 tabs | Tab/Shift-Tab | Up/Down scroll | PgUp/PgDn | r refresh | / filter | q quit

set -u

# ── Terminal Setup ───────────────────────────────────────────────────────────

_tui_init() {
    TERM=${TERM:-xterm}
    COLS=$(tput cols)
    ROWS=$(tput lines)
    ACTIVE_TAB=0
    SCROLL=0
    FILTER=""
    FILTERING=0
    CONTENT=()

    # Colors
    C_RESET=$(tput sgr0)
    C_BOLD=$(tput bold)
    C_DIM=$(tput dim 2>/dev/null || echo "")
    C_REV=$(tput rev)
    C_UL=$(tput smul 2>/dev/null || echo "")

    C_BLK=$(tput setaf 0)
    C_RED=$(tput setaf 1)
    C_GRN=$(tput setaf 2)
    C_YEL=$(tput setaf 3)
    C_BLU=$(tput setaf 4)
    C_MAG=$(tput setaf 5)
    C_CYN=$(tput setaf 6)
    C_WHT=$(tput setaf 7)

    # Bright colors (256-color support)
    C_BRED=$(tput setaf 9 2>/dev/null || echo "$C_RED")
    C_BGRN=$(tput setaf 10 2>/dev/null || echo "$C_GRN")
    C_BYEL=$(tput setaf 11 2>/dev/null || echo "$C_YEL")
    C_BBLU=$(tput setaf 12 2>/dev/null || echo "$C_BLU")
    C_BMAG=$(tput setaf 13 2>/dev/null || echo "$C_MAG")
    C_BCYN=$(tput setaf 14 2>/dev/null || echo "$C_CYN")
    C_BWHT=$(tput setaf 15 2>/dev/null || echo "$C_WHT")

    # Background colors
    BG_BLU=$(tput setab 4)
    BG_CYN=$(tput setab 6)
    BG_GRN=$(tput setab 2)
    BG_RED=$(tput setab 1)
    BG_YEL=$(tput setab 3)
    BG_WHT=$(tput setab 7)
    BG_BLK=$(tput setab 0)
    BG_MAG=$(tput setab 5)

    # Box drawing (Unicode)
    BX_TL="┌" BX_TR="┐" BX_BL="└" BX_BR="┘"
    BX_H="─" BX_V="│" BX_T="┬" BX_B="┴"
    BX_TLR="├" BX_TRR="┤" BX_X="┼"
    BX_TLD="╔" BX_TRD="╗" BX_BLD="╚" BX_BRD="╝"
    BX_HD="═" BX_VD="║"

    TABS=("System" "Services" "Logs" "Network" "Processes" "Certs" "Storage")

    # Tab data cache (indexed by tab number)
    declare -A TAB_CACHE
    declare -A TAB_CACHE_TIME
    LOG_FILE=""  # custom log file for streaming
    CERT_TARGETS=()  # user-added cert targets (host:port)

    # Save terminal state
    tput smcup 2>/dev/null
    tput civis 2>/dev/null
    stty -echo -icanon min 0 time 1 2>/dev/null
}

_tui_cleanup() {
    tput cnorm 2>/dev/null
    tput rmcup 2>/dev/null
    stty sane 2>/dev/null
    echo "${C_RESET}"
}

trap '_tui_cleanup; exit 0' EXIT INT TERM

# ── Drawing Primitives ───────────────────────────────────────────────────────

_goto() { tput cup "$1" "$2"; }
_clear() { tput clear; }

_hline() {
    local y=$1 x=$2 w=$3 ch=${4:-$BX_H} color=${5:-$C_CYN}
    _goto "$y" "$x"
    printf "%s" "$color"
    local i
    for ((i=0; i<w; i++)); do printf "%s" "$ch"; done
    printf "%s" "$C_RESET"
}

_fill_line() {
    local y=$1 color=$2 text=$3
    _goto "$y" 0
    printf "%s%-*s%s" "$color" "$COLS" "$text" "$C_RESET"
}

_print_at() {
    local y=$1 x=$2
    shift 2
    _goto "$y" "$x"
    printf "%s" "$@"
}

# ── Tab Bar ──────────────────────────────────────────────────────────────────

_draw_tabs() {
    local x=0 i label
    local icons=("◈" "⚙" "📋" "🌐" "⚡" "🔒" "💾")

    # Title line (row 0)
    _goto 0 0
    local hostname os_type
    hostname=$(hostname -s 2>/dev/null || hostname)
    os_type=$(uname -s)
    local ts
    ts=$(date +"%H:%M:%S")
    printf "%s ◆ CLE Dashboard  %s│%s  %s%s  %s│%s  %s%s  %s│%s  %s%s %s" \
        "$BG_MAG$C_BWHT$C_BOLD" \
        "$C_BYEL" "$C_BWHT" \
        "$C_BYEL" "$hostname" \
        "$C_BWHT" "$C_BYEL" \
        "$C_BCYN" "$os_type" \
        "$C_BWHT" "$C_BYEL" \
        "$C_BWHT" "$ts" "$C_RESET$BG_MAG"
    printf "%-*s%s" "$((COLS - 50 - ${#hostname} - ${#os_type}))" "" "$C_RESET"

    # Tab bar (row 1)
    _goto 1 0
    x=0
    for ((i=0; i<${#TABS[@]}; i++)); do
        label=" $((i+1)):${TABS[$i]} "
        if [ "$i" -eq "$ACTIVE_TAB" ]; then
            printf "%s %s%s %s" "$BG_CYN$C_BLK$C_BOLD" "${icons[$i]}" "$label" "$C_RESET"
        else
            printf "%s %s%s %s" "$BG_BLK$C_CYN" "${icons[$i]}" "$label" "$C_RESET$BG_BLK"
        fi
        x=$((x + ${#label} + 3))
    done
    printf "%s%-*s%s" "$BG_BLK" "$((COLS - x))" "" "$C_RESET"

    # Separator with styled corners
    _goto 2 0
    printf "%s%s" "$C_BCYN$C_BOLD" "$BX_TLR"
    local j
    for ((j=0; j<COLS-2; j++)); do printf "%s" "$BX_HD"; done
    printf "%s%s" "$BX_TRR" "$C_RESET"
}

# ── Status Bar ───────────────────────────────────────────────────────────────

_draw_status() {
    local total=${#CONTENT[@]}
    local visible=$((ROWS - 5))
    local end=$((SCROLL + visible))
    [ "$end" -gt "$total" ] && end=$total

    # Bottom separator
    _goto $((ROWS - 3)) 0
    printf "%s%s" "$C_BCYN" "$BX_BLD"
    local j
    for ((j=0; j<COLS-2; j++)); do printf "%s" "$BX_HD"; done
    printf "%s%s" "$BX_BRD" "$C_RESET"

    if [ "$FILTERING" -eq 1 ]; then
        _fill_line $((ROWS - 2)) "$BG_GRN$C_BLK$C_BOLD" \
            " 🔍 FILTER: ${FILTER}▌  (Enter=apply  Esc=cancel)"
    else
        local filter_hint=""
        [ -n "$FILTER" ] && filter_hint="  │ Filter: '$FILTER'"
        local logfile_hint=""
        [ -n "$LOG_FILE" ] && [ "$ACTIVE_TAB" -eq 2 ] && logfile_hint="  │ 📄 ${LOG_FILE##*/}"
        _fill_line $((ROWS - 2)) "$BG_BLU$C_BWHT$C_BOLD" \
            " ◈ ${TABS[$ACTIVE_TAB]}  │  $((SCROLL+1))-${end} of ${total} lines${filter_hint}${logfile_hint}"
    fi
    local keys=" 1-7:Tab  ↑↓/jk:Scroll  PgUp/PgDn  r:Refresh  /:Filter  q:Quit"
    [ "$ACTIVE_TAB" -eq 2 ] && keys=" 1-7:Tab  ↑↓/jk:Scroll  L:LogFile  r:Refresh  /:Filter  q:Quit"
    [ "$ACTIVE_TAB" -eq 5 ] && keys=" 1-7:Tab  ↑↓/jk:Scroll  P:Add Port  r:Refresh  /:Filter  q:Quit"
    _fill_line $((ROWS - 1)) "$BG_BLK$C_CYN" "$keys"
}

# ── Content Rendering ────────────────────────────────────────────────────────

_colorize_line() {
    local line="$1"
    local lower
    lower=$(echo "$line" | tr '[:upper:]' '[:lower:]')

    case "$lower" in
        *"== "*|*"── "*)
            printf "%s %s %s" "$C_BCYN$C_BOLD" "$line" "$C_RESET" ;;
        *"-- "*)
            printf "%s%s%s" "$C_MAG$C_BOLD" "$line" "$C_RESET" ;;
        *"expired"*|*error*|*fail*|*fatal*|*critical*|*"\[fail\]"*|*panic*)
            printf "%s ✗ %s%s" "$C_BRED" "$line" "$C_RESET" ;;
        *warn*)
            printf "%s ⚠ %s%s" "$C_BYEL" "$line" "$C_RESET" ;;
        *running*|*"\[run\]"*|*active*|*" ok "*)
            printf "%s%s%s" "$C_BGRN" "$line" "$C_RESET" ;;
        *"subject:"*|*"issuer:"*|*"valid from:"*|*"expires:"*|*"serial:"*|*"sans:"*)
            printf "%s%s%s" "$C_BCYN" "$line" "$C_RESET" ;;
        *"\[stop\]"*|*inactive*|*dead*)
            printf "%s%s%s" "$C_DIM$C_WHT" "$line" "$C_RESET" ;;
        *"hostname:"*|*"os:"*|*"arch"*|*"cores:"*|*"load"*|*"uptime:"*|*"date:"*|*"users"*|*"total ram"*|*"python:"*)
            printf "%s  ▸ %s%s" "$C_BWHT" "$line" "$C_RESET" ;;
        *"ram:"*|*"swap:"*|*"disk"*)
            printf "%s%s%s" "$C_BMAG" "$line" "$C_RESET" ;;
        *"listen"*|*"established"*)
            printf "%s%s%s" "$C_BGRN" "$line" "$C_RESET" ;;
        *"info"*|*debug*|*"source:"*)
            printf "%s%s%s" "$C_BLU" "$line" "$C_RESET" ;;
        *"press "*|*"usage"*)
            printf "%s%s%s" "$C_BYEL$C_DIM" "$line" "$C_RESET" ;;
        *)
            printf "%s%s%s" "$C_WHT" "$line" "$C_RESET" ;;
    esac
}

_draw_content() {
    local visible=$((ROWS - 5))
    local total=${#CONTENT[@]}
    local i y line

    for ((y=0; y<visible; y++)); do
        i=$((SCROLL + y))
        _goto $((y + 3)) 0

        if [ "$i" -ge "$total" ]; then
            printf "%-*s" "$COLS" ""
            continue
        fi

        line="${CONTENT[$i]}"
        # Truncate to terminal width
        if [ "${#line}" -gt "$((COLS - 1))" ]; then
            line="${line:0:$((COLS - 4))}..."
        fi
        printf "%-*s" "$COLS" ""
        _goto $((y + 3)) 0
        _colorize_line "$line"
    done

    # Scrollbar
    if [ "$total" -gt "$visible" ] && [ "$visible" -gt 0 ]; then
        local sb_h=$((visible * visible / total))
        [ "$sb_h" -lt 1 ] && sb_h=1
        local sb_pos=$((SCROLL * visible / total))
        for ((y=0; y<visible; y++)); do
            _goto $((y + 3)) $((COLS - 1))
            if [ "$y" -ge "$sb_pos" ] && [ "$y" -lt "$((sb_pos + sb_h))" ]; then
                printf "%s▓%s" "$C_BCYN" "$C_RESET"
            else
                printf "%s░%s" "$C_BLK" "$C_RESET"
            fi
        done
    fi
}

# ── Data Collectors ──────────────────────────────────────────────────────────

_collect_system() {
    CONTENT=()
    local fqdn hostname os kernel arch
    fqdn=$(hostname -f 2>/dev/null || hostname)
    hostname=$(hostname -s 2>/dev/null || hostname)
    os=$(uname -s)
    kernel=$(uname -r)
    arch=$(uname -m)

    CONTENT+=("== ◈ SYSTEM INFORMATION ==")
    CONTENT+=("")
    CONTENT+=("  Hostname:     $fqdn")
    CONTENT+=("  Short Name:   $hostname")
    CONTENT+=("  OS:           $os $kernel")
    CONTENT+=("  Architecture: $arch")
    CONTENT+=("  Python:       $(python3 --version 2>/dev/null | cut -d' ' -f2 || echo 'N/A')")
    CONTENT+=("  Shell:        $SHELL")
    CONTENT+=("  Date:         $(date '+%Y-%m-%d %H:%M:%S %Z')")
    CONTENT+=("")

    local uptime_str
    uptime_str=$(uptime 2>/dev/null)
    CONTENT+=("  Uptime:       $uptime_str")
    CONTENT+=("")

    CONTENT+=("== ⚡ CPU ==")
    CONTENT+=("")
    local ncpu
    ncpu=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo "?")
    CONTENT+=("  Cores:        $ncpu")

    local loadavg
    loadavg=$(cat /proc/loadavg 2>/dev/null || sysctl -n vm.loadavg 2>/dev/null | tr -d '{}')
    [ -n "$loadavg" ] && CONTENT+=("  Load Average: $loadavg")
    CONTENT+=("")

    CONTENT+=("== 🧠 MEMORY ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            case "$line" in
                Mem:*)
                    set -- $line
                    local pct=$(( $3 * 100 / $2 ))
                    local bar_w=30 filled=$(( pct * 30 / 100 ))
                    local bar_str=""
                    local j
                    for ((j=0; j<bar_w; j++)); do
                        if [ $j -lt $filled ]; then bar_str+="█"; else bar_str+="░"; fi
                    done
                    if [ $pct -gt 80 ]; then
                        CONTENT+=("  RAM:  ${C_BRED}${bar_str}${C_RESET} ${3}M / ${2}M (${pct}%)")
                    elif [ $pct -gt 50 ]; then
                        CONTENT+=("  RAM:  ${C_BYEL}${bar_str}${C_RESET} ${3}M / ${2}M (${pct}%)")
                    else
                        CONTENT+=("  RAM:  ${C_BGRN}${bar_str}${C_RESET} ${3}M / ${2}M (${pct}%)")
                    fi
                    ;;
                Swap:*)
                    set -- $line
                    local pct=0
                    [ "$2" -gt 0 ] 2>/dev/null && pct=$(( $3 * 100 / $2 ))
                    CONTENT+=("  Swap: ${3}M / ${2}M (${pct}%)")
                    ;;
            esac
        done < <(free -m 2>/dev/null)
    else
        local memsize
        memsize=$(sysctl -n hw.memsize 2>/dev/null)
        [ -n "$memsize" ] && CONTENT+=("  Total RAM: $(( memsize / 1073741824 )) GB")
    fi
    CONTENT+=("")

    CONTENT+=("== 💾 DISK ==")
    CONTENT+=("")
    while IFS= read -r line; do
        CONTENT+=("  $line")
    done < <(df -h / /home /tmp /var 2>/dev/null | sort -u)
    CONTENT+=("")

    CONTENT+=("== 👤 USERS ==")
    CONTENT+=("")
    local nusers
    nusers=$(who 2>/dev/null | wc -l | tr -d ' ')
    CONTENT+=("  Logged in: $nusers")
    while IFS= read -r line; do
        CONTENT+=("  $line")
    done < <(who 2>/dev/null)
}

_collect_services() {
    CONTENT=()
    local os
    os=$(uname -s)

    if [ "$os" = "Linux" ] && command -v systemctl >/dev/null 2>&1; then
        CONTENT+=("== ✅ RUNNING SERVICES ==")
        CONTENT+=("")
        local run_count=0
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_BGRN}●${C_RESET} $name")
            run_count=$((run_count + 1))
        done < <(systemctl list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | head -40)
        CONTENT+=("  ${C_BGRN}── $run_count services running ──${C_RESET}")

        CONTENT+=("")
        CONTENT+=("== ❌ FAILED SERVICES ==")
        CONTENT+=("")
        local has_failed=0
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_BRED}✗${C_RESET} ${C_BRED}$name${C_RESET}")
            has_failed=1
        done < <(systemctl list-units --type=service --state=failed --no-pager --no-legend 2>/dev/null)
        [ $has_failed -eq 0 ] && CONTENT+=("  ${C_BGRN}✓ No failed services${C_RESET}")

        CONTENT+=("")
        CONTENT+=("== ⏹ STOPPED SERVICES ==")
        CONTENT+=("")
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_DIM}○${C_RESET} ${C_DIM}$name${C_RESET}")
        done < <(systemctl list-units --type=service --state=inactive --no-pager --no-legend 2>/dev/null | head -25)

    elif [ "$os" = "Darwin" ]; then
        CONTENT+=("== LAUNCHCTL SERVICES ==")
        CONTENT+=("")
        while IFS=$'\t' read -r pid status name; do
            if [ "$pid" != "-" ] && [ "$pid" != "PID" ]; then
                CONTENT+=("  ${C_BGRN}●${C_RESET} $name  (PID: $pid)")
            else
                CONTENT+=("  ${C_DIM}○${C_RESET} ${C_DIM}$name${C_RESET}")
            fi
        done < <(launchctl list 2>/dev/null | head -50)
    else
        CONTENT+=("Service listing not supported on this platform")
    fi
}

_collect_logs() {
    CONTENT=()
    local os
    os=$(uname -s)

    # Custom log file mode
    if [ -n "$LOG_FILE" ] && [ -f "$LOG_FILE" ]; then
        CONTENT+=("== LOG FILE: $LOG_FILE ==")
        CONTENT+=("  (Press L to change file, R to refresh)")
        CONTENT+=("")
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(tail -200 "$LOG_FILE" 2>/dev/null)
        return
    fi

    CONTENT+=("== 📋 SYSTEM LOGS  (Press L to select a log file) ==")
    CONTENT+=("")

    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(journalctl --no-pager -n 100 --output=short 2>/dev/null || \
                 tail -100 /var/log/syslog 2>/dev/null || \
                 tail -100 /var/log/messages 2>/dev/null || \
                 echo "No log source available")
    elif [ "$os" = "Darwin" ]; then
        # Use /var/log/system.log or install.log instead of slow `log show`
        local logfile=""
        for lf in /var/log/system.log /var/log/install.log /var/log/wifi.log; do
            [ -r "$lf" ] && { logfile="$lf"; break; }
        done
        if [ -n "$logfile" ]; then
            CONTENT+=("  (Source: $logfile)")
            CONTENT+=("")
            while IFS= read -r line; do
                CONTENT+=("$line")
            done < <(tail -100 "$logfile" 2>/dev/null)
        else
            while IFS= read -r line; do
                CONTENT+=("$line")
            done < <(log show --last 1m --style compact 2>/dev/null | tail -50)
        fi
    fi

    CONTENT+=("")
    CONTENT+=("== AVAILABLE LOG FILES ==")
    CONTENT+=("")
    local lf
    for lf in /var/log/syslog /var/log/messages /var/log/auth.log /var/log/kern.log \
               /var/log/dmesg /var/log/secure /var/log/cron /var/log/boot.log \
               /var/log/system.log /var/log/install.log /var/log/wifi.log \
               /var/log/httpd/access_log /var/log/httpd/error_log \
               /var/log/nginx/access.log /var/log/nginx/error.log \
               /var/log/audit/audit.log; do
        [ -r "$lf" ] && CONTENT+=("  ${C_BGRN}●${C_RESET} $lf  ($(du -h "$lf" 2>/dev/null | cut -f1))")
    done
    CONTENT+=("")
    CONTENT+=("  Press ${C_BYEL}L${C_RESET} to enter a log file path for streaming")
}

_collect_network() {
    CONTENT=()
    local os
    os=$(uname -s)

    CONTENT+=("== 🌐 NETWORK INTERFACES ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(ip -br addr 2>/dev/null || ifconfig -a 2>/dev/null | head -40)
    else
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(ifconfig 2>/dev/null | grep -E '(^[a-z]|inet )' | head -30)
    fi

    CONTENT+=("")
    CONTENT+=("== 🔌 LISTENING PORTS ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(ss -tlnp 2>/dev/null | head -25)
    else
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(lsof -i -P -n 2>/dev/null | grep LISTEN | head -25)
    fi

    CONTENT+=("")
    CONTENT+=("== 🛣 ROUTING TABLE ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(ip route 2>/dev/null | head -15)
    else
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(netstat -rn 2>/dev/null | head -15)
    fi

    CONTENT+=("")
    CONTENT+=("== 📡 DNS CONFIGURATION ==")
    CONTENT+=("")
    while IFS= read -r line; do
        CONTENT+=("  $line")
    done < <(grep -E '^(nameserver|search|domain)' /etc/resolv.conf 2>/dev/null)

    CONTENT+=("")
    CONTENT+=("== 🔗 ACTIVE CONNECTIONS ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(ss -tnp 2>/dev/null | head -20)
    else
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(netstat -an 2>/dev/null | grep ESTABLISHED | head -20)
    fi
}

_collect_processes() {
    CONTENT=()
    local os
    os=$(uname -s)

    CONTENT+=("== ⚡ TOP PROCESSES BY CPU ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(ps aux --sort=-%cpu 2>/dev/null | head -20)
    else
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(ps aux -r 2>/dev/null | head -20)
    fi

    CONTENT+=("")
    CONTENT+=("== 🧠 TOP PROCESSES BY MEMORY ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(ps aux --sort=-%mem 2>/dev/null | head -15)
    else
        while IFS= read -r line; do
            CONTENT+=("$line")
        done < <(ps aux -m 2>/dev/null | head -15)
    fi
}

_check_port_open() {
    local host="$1" port="$2"
    if command -v nc >/dev/null 2>&1; then
        nc -z -w2 "$host" "$port" 2>/dev/null
    elif command -v ncat >/dev/null 2>&1; then
        ncat -z -w2 "$host" "$port" 2>/dev/null
    else
        (echo >/dev/tcp/"$host"/"$port") 2>/dev/null
    fi
}

_get_starttls_flag() {
    local port="$1"
    case "$port" in
        25|587)  echo "-starttls smtp" ;;
        143)     echo "-starttls imap" ;;
        110)     echo "-starttls pop3" ;;
        21)      echo "-starttls ftp" ;;
        *)       echo "" ;;
    esac
}

_collect_certs() {
    CONTENT=()
    local targets=("$@")

    if [ ${#CERT_TARGETS[@]} -gt 0 ]; then
        targets+=("${CERT_TARGETS[@]}")
    fi

    if [ ${#targets[@]} -eq 0 ]; then
        local port
        for port in 443 8443 636 993 995; do
            if _check_port_open localhost "$port"; then
                targets+=("localhost:$port")
            fi
        done
        [ ${#targets[@]} -eq 0 ] && targets=("localhost:443")
    fi

    # Deduplicate targets
    local unique=() seen="" t
    for t in "${targets[@]}"; do
        case "$seen" in
            *"|$t|"*) ;;
            *) unique+=("$t"); seen="$seen|$t|" ;;
        esac
    done
    targets=("${unique[@]}")

    CONTENT+=("== 🔒 SSL/TLS CERTIFICATES ==")
    CONTENT+=("  Press ${C_BYEL}P${C_RESET} to add a host:port  │  ${#targets[@]} target(s) configured")
    CONTENT+=("")

    local target host port_s starttls_flag
    for target in "${targets[@]}"; do
        if [[ "$target" != *:* ]]; then
            target="$target:443"
        fi
        host="${target%:*}"
        port_s="${target##*:}"
        starttls_flag=$(_get_starttls_flag "$port_s")

        CONTENT+=("── 🔐 $target ──")
        CONTENT+=("")

        if ! _check_port_open "$host" "$port_s"; then
            CONTENT+=("  ${C_BRED}✗ Port $port_s is not reachable on $host${C_RESET}")
            CONTENT+=("")
            continue
        fi

        local cert_out _timeout_cmd=""
        if command -v timeout >/dev/null 2>&1; then
            _timeout_cmd="timeout 5"
        elif command -v gtimeout >/dev/null 2>&1; then
            _timeout_cmd="gtimeout 5"
        fi
        cert_out=$(${_timeout_cmd} bash -c "echo | openssl s_client -connect '$target' -servername '$host' $starttls_flag 2>/dev/null" | openssl x509 -noout -subject -issuer -dates -serial -ext subjectAltName 2>/dev/null)
        if [ -n "$cert_out" ]; then
            while IFS= read -r line; do
                case "$line" in
                    *subject*) CONTENT+=("  ${C_BCYN}Subject:${C_RESET}    ${line#*= }") ;;
                    *issuer*)  CONTENT+=("  ${C_BCYN}Issuer:${C_RESET}     ${line#*= }") ;;
                    *notBefore*) CONTENT+=("  ${C_BCYN}Valid From:${C_RESET} ${line#*=}") ;;
                    *notAfter*)
                        local expiry="${line#*=}"
                        local now_epoch exp_epoch days_left
                        now_epoch=$(date +%s)
                        exp_epoch=$(date -d "$expiry" +%s 2>/dev/null || date -j -f "%b %d %T %Y %Z" "$expiry" +%s 2>/dev/null || echo 0)
                        if [ "$exp_epoch" -gt 0 ] 2>/dev/null; then
                            days_left=$(( (exp_epoch - now_epoch) / 86400 ))
                            if [ "$days_left" -lt 0 ]; then
                                CONTENT+=("  ${C_BRED}Expires:${C_RESET}    $expiry ${C_BRED}⚠ EXPIRED!${C_RESET}")
                            elif [ "$days_left" -lt 30 ]; then
                                CONTENT+=("  ${C_BYEL}Expires:${C_RESET}    $expiry ${C_BYEL}⚠ ${days_left}d left${C_RESET}")
                            else
                                CONTENT+=("  ${C_BGRN}Expires:${C_RESET}    $expiry ${C_BGRN}✓ ${days_left}d left${C_RESET}")
                            fi
                        else
                            CONTENT+=("  ${C_BCYN}Expires:${C_RESET}    $expiry")
                        fi
                        ;;
                    *serial*)  CONTENT+=("  ${C_BCYN}Serial:${C_RESET}     ${line#*=}") ;;
                    *DNS:*|*IP:*)
                        CONTENT+=("  ${C_BCYN}SANs:${C_RESET}")
                        local san_entry
                        local san_list
                        san_list=$(echo "$line" | tr ',' '\n')
                        while IFS= read -r san_entry; do
                            san_entry=$(echo "$san_entry" | sed 's/^[[:space:]]*//')
                            [ -z "$san_entry" ] && continue
                            case "$san_entry" in
                                DNS:*) CONTENT+=("    ${C_BGRN}◦${C_RESET} ${san_entry#DNS:}") ;;
                                IP:*)  CONTENT+=("    ${C_BYEL}◦${C_RESET} ${san_entry}") ;;
                                othername:*) CONTENT+=("    ${C_DIM}◦ ${san_entry}${C_RESET}") ;;
                                *) CONTENT+=("    ${C_DIM}◦ ${san_entry}${C_RESET}") ;;
                            esac
                        done <<< "$san_list"
                        ;;
                esac
            done <<< "$cert_out"
        else
            if [ -n "$starttls_flag" ]; then
                CONTENT+=("  ${C_BYEL}⚠ No SSL certificate (STARTTLS attempted for port $port_s)${C_RESET}")
            else
                CONTENT+=("  ${C_BYEL}⚠ No SSL certificate on this port${C_RESET}")
            fi
        fi
        CONTENT+=("")
    done
}

_collect_storage() {
    CONTENT=()
    local os
    os=$(uname -s)

    CONTENT+=("== 💾 FILESYSTEM USAGE ==")
    CONTENT+=("")
    while IFS= read -r line; do
        # Colorize usage percentage
        local pct
        pct=$(echo "$line" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
        if [ -n "$pct" ] && [ "$pct" -gt 90 ] 2>/dev/null; then
            CONTENT+=("${C_BRED}$line${C_RESET}")
        elif [ -n "$pct" ] && [ "$pct" -gt 70 ] 2>/dev/null; then
            CONTENT+=("${C_BYEL}$line${C_RESET}")
        else
            CONTENT+=("  $line")
        fi
    done < <(df -h 2>/dev/null)

    CONTENT+=("")
    CONTENT+=("== 📁 MOUNT POINTS ==")
    CONTENT+=("")
    while IFS= read -r line; do
        CONTENT+=("  ${line:0:120}")
    done < <(mount 2>/dev/null | head -20)

    if [ "$os" = "Linux" ] && command -v lsblk >/dev/null 2>&1; then
        CONTENT+=("")
        CONTENT+=("== BLOCK DEVICES ==")
        CONTENT+=("")
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null | head -20)
    fi
}

# ── Log File Selector ────────────────────────────────────────────────────────

_select_logfile() {
    local input=""
    _fill_line $((ROWS - 2)) "$BG_GRN$C_BLK$C_BOLD" \
        " Enter log file path (Enter=confirm, Esc=cancel, empty=system logs): "

    # Simple inline text input
    tput cnorm 2>/dev/null
    while true; do
        _fill_line $((ROWS - 3)) "$BG_BLK$C_BWHT" " > ${input}▌"
        IFS= read -rsn1 ch 2>/dev/null
        case "$ch" in
            $'\e')
                tput civis 2>/dev/null
                return ;;
            "") # Enter
                LOG_FILE="$input"
                SCROLL=0
                tput civis 2>/dev/null
                return ;;
            $'\177'|$'\b') input="${input%?}" ;;
            *)
                if [ ${#ch} -eq 1 ] && [ "$(printf '%d' "'$ch")" -ge 32 ] 2>/dev/null; then
                    input+="$ch"
                fi
                ;;
        esac
    done
}

_select_cert_target() {
    local input=""
    _fill_line $((ROWS - 2)) "$BG_MAG$C_BWHT$C_BOLD" \
        " 🔒 Enter host:port (e.g. google.com:443). Enter=confirm, Esc=cancel: "

    tput cnorm 2>/dev/null
    while true; do
        _fill_line $((ROWS - 3)) "$BG_BLK$C_BWHT" " > ${input}▌"
        IFS= read -rsn1 ch 2>/dev/null
        case "$ch" in
            $'\e')
                tput civis 2>/dev/null
                return ;;
            "")
                if [ -n "$input" ]; then
                    [[ "$input" != *:* ]] && input="$input:443"
                    CERT_TARGETS+=("$input")
                fi
                SCROLL=0
                tput civis 2>/dev/null
                return ;;
            $'\177'|$'\b') input="${input%?}" ;;
            *)
                if [ ${#ch} -eq 1 ] && [ "$(printf '%d' "'$ch")" -ge 32 ] 2>/dev/null; then
                    input+="$ch"
                fi
                ;;
        esac
    done
}

# ── Content Filtering ────────────────────────────────────────────────────────

_filter_content() {
    if [ -z "$FILTER" ]; then
        return
    fi
    local filtered=() line lower_filter lower_line
    lower_filter=$(echo "$FILTER" | tr '[:upper:]' '[:lower:]')
    for line in "${CONTENT[@]}"; do
        lower_line=$(echo "$line" | tr '[:upper:]' '[:lower:]')
        if [[ "$lower_line" == *"$lower_filter"* ]]; then
            filtered+=("$line")
        fi
    done
    CONTENT=("${filtered[@]}")
}

# ── Tab Data Loading ─────────────────────────────────────────────────────────

_show_loading() {
    local center_row=$(( (ROWS - 3) / 2 + 3 ))
    local msg="  ⟳  Loading ${TABS[$ACTIVE_TAB]}...  "
    local center_col=$(( (COLS - ${#msg}) / 2 ))
    [ $center_col -lt 0 ] && center_col=2
    _goto $center_row $center_col
    printf "%s%s%s" "$BG_BLU$C_BWHT$C_BOLD" "$msg" "$C_RESET"
}

_load_tab() {
    local force=${FORCE_REFRESH:-0}
    local now
    now=$(date +%s)
    local cached_time=${TAB_CACHE_TIME[$ACTIVE_TAB]:-0}

    # Use cache if data is less than 15 seconds old (unless forced)
    if [ "$force" -eq 0 ] && [ "$((now - cached_time))" -lt 15 ] && [ -n "${TAB_CACHE[$ACTIVE_TAB]:-}" ]; then
        IFS=$'\x01' read -ra CONTENT <<< "${TAB_CACHE[$ACTIVE_TAB]}"
        [ -n "$FILTER" ] && _filter_content
        return
    fi

    _show_loading

    case "$ACTIVE_TAB" in
        0) _collect_system ;;
        1) _collect_services ;;
        2) _collect_logs ;;
        3) _collect_network ;;
        4) _collect_processes ;;
        5) _collect_certs "$@" ;;
        6) _collect_storage ;;
    esac

    # Store in cache
    local IFS=$'\x01'
    TAB_CACHE[$ACTIVE_TAB]="${CONTENT[*]}"
    TAB_CACHE_TIME[$ACTIVE_TAB]=$now

    [ -n "$FILTER" ] && _filter_content
}

# ── Input Handling ───────────────────────────────────────────────────────────

_handle_input() {
    local key="" escape_seq=""
    IFS= read -rsn1 key 2>/dev/null || return 1

    # Handle escape sequences
    if [ "$key" = $'\e' ]; then
        IFS= read -rsn1 -t 0.1 key2 2>/dev/null
        if [ "$key2" = "[" ]; then
            IFS= read -rsn1 -t 0.1 key3 2>/dev/null
            case "$key3" in
                A) key="UP" ;;     # Up arrow
                B) key="DOWN" ;;   # Down arrow
                C) key="RIGHT" ;;
                D) key="LEFT" ;;
                5) IFS= read -rsn1 -t 0.1 _ 2>/dev/null; key="PGUP" ;;
                6) IFS= read -rsn1 -t 0.1 _ 2>/dev/null; key="PGDN" ;;
                H) key="HOME" ;;
                F) key="END" ;;
                Z) key="BTAB" ;;   # Shift-Tab
            esac
        elif [ -z "$key2" ]; then
            if [ "$FILTERING" -eq 1 ]; then
                FILTERING=0
                FILTER=""
                SCROLL=0
                return 0
            fi
        fi
    fi

    local visible=$((ROWS - 5))
    local total=${#CONTENT[@]}

    # Filter mode
    if [ "$FILTERING" -eq 1 ]; then
        case "$key" in
            "") # Enter
                FILTERING=0
                SCROLL=0
                _load_tab "$@"
                ;;
            $'\177'|$'\b') # Backspace
                FILTER="${FILTER%?}"
                ;;
            *)
                if [ ${#key} -eq 1 ] && [ "$(printf '%d' "'$key")" -ge 32 ] 2>/dev/null; then
                    FILTER+="$key"
                fi
                ;;
        esac
        return 0
    fi

    case "$key" in
        q|Q) return 1 ;;
        /) FILTERING=1; FILTER="" ;;
        l|L)
            if [ "$ACTIVE_TAB" -eq 2 ]; then
                _select_logfile
                FORCE_REFRESH=1
                _load_tab "$@"
                FORCE_REFRESH=0
            fi
            ;;
        p|P)
            if [ "$ACTIVE_TAB" -eq 5 ]; then
                _select_cert_target
                FORCE_REFRESH=1
                _load_tab "$@"
                FORCE_REFRESH=0
            fi
            ;;
        r|R)
            SCROLL=0
            FORCE_REFRESH=1
            _load_tab "$@"
            FORCE_REFRESH=0
            ;;
        UP|k) [ "$SCROLL" -gt 0 ] && SCROLL=$((SCROLL - 1)) ;;
        DOWN|j) [ "$SCROLL" -lt "$((total - visible))" ] 2>/dev/null && SCROLL=$((SCROLL + 1)) ;;
        PGUP) SCROLL=$((SCROLL - visible)); [ "$SCROLL" -lt 0 ] && SCROLL=0 ;;
        PGDN)
            SCROLL=$((SCROLL + visible))
            local max=$((total - visible))
            [ "$max" -lt 0 ] && max=0
            [ "$SCROLL" -gt "$max" ] && SCROLL=$max
            ;;
        HOME|g) SCROLL=0 ;;
        END|G) SCROLL=$((total - visible)); [ "$SCROLL" -lt 0 ] && SCROLL=0 ;;
        $'\t') # Tab
            ACTIVE_TAB=$(( (ACTIVE_TAB + 1) % ${#TABS[@]} ))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
        BTAB) # Shift-Tab
            ACTIVE_TAB=$(( (ACTIVE_TAB - 1 + ${#TABS[@]}) % ${#TABS[@]} ))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
        [1-7])
            ACTIVE_TAB=$((key - 1))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
    esac
    return 0
}

# ── Main Loop ────────────────────────────────────────────────────────────────

main() {
    _tui_init
    _clear

    local cert_targets=("$@")
    FORCE_REFRESH=1
    _load_tab "${cert_targets[@]}"
    FORCE_REFRESH=0

    local last_refresh
    last_refresh=$(date +%s)

    while true; do
        # Handle terminal resize
        local new_cols new_rows
        new_cols=$(tput cols)
        new_rows=$(tput lines)
        if [ "$new_cols" != "$COLS" ] || [ "$new_rows" != "$ROWS" ]; then
            COLS=$new_cols
            ROWS=$new_rows
            _clear
        fi

        _draw_tabs
        _draw_content
        _draw_status

        if ! _handle_input "${cert_targets[@]}"; then
            break
        fi

        # Auto-refresh every 30 seconds (cache handles 15s dedup)
        local now
        now=$(date +%s)
        if [ $((now - last_refresh)) -ge 30 ]; then
            FORCE_REFRESH=1
            _load_tab "${cert_targets[@]}"
            FORCE_REFRESH=0
            last_refresh=$now
        fi
    done
}

main "$@"
