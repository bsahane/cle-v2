#!/usr/bin/env bash
#
# CLE Dashboard - nmtui-style TUI host monitoring
# Pure bash + tput - no external dependencies
#
# Usage: cle-dashboard [host:port ...]
# Keys:  1-7 tabs | Tab/Shift-Tab | Up/Down scroll | PgUp/PgDn | r refresh | / filter | q quit

set -u

# ── Terminal Setup ───────────────────────────────────────────────────────────

_tui_init() {
    TERM=${TERM:-xterm}
    COLS=$(tput cols)
    ROWS=$(tput lines)
    ACTIVE_TAB=0
    SCROLL=0
    FILTER=""
    FILTERING=0
    CONTENT=()

    # Colors
    C_RESET=$(tput sgr0)
    C_BOLD=$(tput bold)
    C_DIM=$(tput dim 2>/dev/null || echo "")
    C_REV=$(tput rev)
    C_UL=$(tput smul 2>/dev/null || echo "")

    C_BLK=$(tput setaf 0)
    C_RED=$(tput setaf 1)
    C_GRN=$(tput setaf 2)
    C_YEL=$(tput setaf 3)
    C_BLU=$(tput setaf 4)
    C_MAG=$(tput setaf 5)
    C_CYN=$(tput setaf 6)
    C_WHT=$(tput setaf 7)

    # Bright colors (256-color support)
    C_BRED=$(tput setaf 9 2>/dev/null || echo "$C_RED")
    C_BGRN=$(tput setaf 10 2>/dev/null || echo "$C_GRN")
    C_BYEL=$(tput setaf 11 2>/dev/null || echo "$C_YEL")
    C_BBLU=$(tput setaf 12 2>/dev/null || echo "$C_BLU")
    C_BMAG=$(tput setaf 13 2>/dev/null || echo "$C_MAG")
    C_BCYN=$(tput setaf 14 2>/dev/null || echo "$C_CYN")
    C_BWHT=$(tput setaf 15 2>/dev/null || echo "$C_WHT")

    # Background colors
    BG_BLU=$(tput setab 4)
    BG_CYN=$(tput setab 6)
    BG_GRN=$(tput setab 2)
    BG_RED=$(tput setab 1)
    BG_YEL=$(tput setab 3)
    BG_WHT=$(tput setab 7)
    BG_BLK=$(tput setab 0)
    BG_MAG=$(tput setab 5)

    # Box drawing (Unicode)
    BX_TL="┌" BX_TR="┐" BX_BL="└" BX_BR="┘"
    BX_H="─" BX_V="│" BX_T="┬" BX_B="┴"
    BX_TLR="├" BX_TRR="┤" BX_X="┼"
    BX_TLD="╔" BX_TRD="╗" BX_BLD="╚" BX_BRD="╝"
    BX_HD="═" BX_VD="║"

    TABS=("System" "Services" "Logs" "Network" "Processes" "Certs" "Storage" "Security" "Terminal")

    # Tab data cache (indexed by tab number)
    declare -A TAB_CACHE
    declare -A TAB_CACHE_TIME
    LOG_FILE=""  # custom log file for streaming
    CERT_TARGETS=()  # user-added cert targets (host:port)

    # Save terminal state
    tput smcup 2>/dev/null
    tput civis 2>/dev/null
    stty -echo -icanon min 0 time 1 2>/dev/null
}

_tui_cleanup() {
    tput cnorm 2>/dev/null
    tput rmcup 2>/dev/null
    stty sane 2>/dev/null
    echo "${C_RESET}"
}

trap '_tui_cleanup; exit 0' EXIT INT TERM

# ── Drawing Primitives ───────────────────────────────────────────────────────

_goto() { tput cup "$1" "$2"; }
_clear() { tput clear; }

_hline() {
    local y=$1 x=$2 w=$3 ch=${4:-$BX_H} color=${5:-$C_CYN}
    _goto "$y" "$x"
    printf "%s" "$color"
    local i
    for ((i=0; i<w; i++)); do printf "%s" "$ch"; done
    printf "%s" "$C_RESET"
}

_fill_line() {
    local y=$1 color=$2 text=$3
    _goto "$y" 0
    printf "%s%-*s%s" "$color" "$COLS" "$text" "$C_RESET"
}

_print_at() {
    local y=$1 x=$2
    shift 2
    _goto "$y" "$x"
    printf "%s" "$@"
}

# ── Progress Bar Helper ────────────────────────────────────────────────────────

_progress_bar() {
    local pct=$1 width=${2:-30} label=${3:-""}
    local filled=$(( pct * width / 100 ))
    local bar="" j

    for ((j=0; j<width; j++)); do
        if [ $j -lt $filled ]; then
            if [ $pct -gt 90 ]; then
                bar+="${C_BRED}█"
            elif [ $pct -gt 70 ]; then
                bar+="${C_BYEL}█"
            elif [ $pct -gt 50 ]; then
                bar+="${C_BCYN}█"
            else
                bar+="${C_BGRN}█"
            fi
        else
            bar+="${C_BLK}░"
        fi
    done
    printf "%s%s%s %s%d%%%s" "$bar" "$C_RESET" "" "$C_BOLD" "$pct" "$C_RESET"
    [ -n "$label" ] && printf " %s" "$label"
}

# ── Tab Bar ──────────────────────────────────────────────────────────────────

_draw_tabs() {
    local x=0 i label
    local icons=("◈" "⚙" "📋" "🌐" "⚡" "🔒" "💾" "🛡" "🖥")

    # Title line (row 0)
    _goto 0 0
    local hostname os_type
    hostname=$(hostname -s 2>/dev/null || hostname)
    os_type=$(uname -s)
    local ts
    ts=$(date +"%H:%M:%S")
    printf "%s ◆ CLE Dashboard  %s│%s  %s%s  %s│%s  %s%s  %s│%s  %s%s %s" \
        "$BG_MAG$C_BWHT$C_BOLD" \
        "$C_BYEL" "$C_BWHT" \
        "$C_BYEL" "$hostname" \
        "$C_BWHT" "$C_BYEL" \
        "$C_BCYN" "$os_type" \
        "$C_BWHT" "$C_BYEL" \
        "$C_BWHT" "$ts" "$C_RESET$BG_MAG"
    printf "%-*s%s" "$((COLS - 50 - ${#hostname} - ${#os_type}))" "" "$C_RESET"

    # Tab bar (row 1)
    _goto 1 0
    x=0
    for ((i=0; i<${#TABS[@]}; i++)); do
        label=" $((i+1)):${TABS[$i]} "
        if [ "$i" -eq "$ACTIVE_TAB" ]; then
            printf "%s %s%s %s" "$BG_CYN$C_BLK$C_BOLD" "${icons[$i]}" "$label" "$C_RESET"
        else
            printf "%s %s%s %s" "$BG_BLK$C_CYN" "${icons[$i]}" "$label" "$C_RESET$BG_BLK"
        fi
        x=$((x + ${#label} + 3))
    done
    printf "%s%-*s%s" "$BG_BLK" "$((COLS - x))" "" "$C_RESET"

    # Separator with styled corners
    _goto 2 0
    printf "%s%s" "$C_BCYN$C_BOLD" "$BX_TLR"
    local j
    for ((j=0; j<COLS-2; j++)); do printf "%s" "$BX_HD"; done
    printf "%s%s" "$BX_TRR" "$C_RESET"
}

# ── Status Bar ───────────────────────────────────────────────────────────────

_draw_status() {
    local total=${#CONTENT[@]}
    local visible=$((ROWS - 5))
    local end=$((SCROLL + visible))
    [ "$end" -gt "$total" ] && end=$total

    # Bottom separator
    _goto $((ROWS - 3)) 0
    printf "%s%s" "$C_BCYN" "$BX_BLD"
    local j
    for ((j=0; j<COLS-2; j++)); do printf "%s" "$BX_HD"; done
    printf "%s%s" "$BX_BRD" "$C_RESET"

    if [ "$FILTERING" -eq 1 ]; then
        _fill_line $((ROWS - 2)) "$BG_GRN$C_BLK$C_BOLD" \
            " 🔍 FILTER: ${FILTER}▌  (Enter=apply  Esc=cancel)"
    else
        local filter_hint=""
        [ -n "$FILTER" ] && filter_hint="  │ Filter: '$FILTER'"
        local logfile_hint=""
        [ -n "$LOG_FILE" ] && [ "$ACTIVE_TAB" -eq 2 ] && logfile_hint="  │ 📄 ${LOG_FILE##*/}"
        _fill_line $((ROWS - 2)) "$BG_BLU$C_BWHT$C_BOLD" \
            " ◈ ${TABS[$ACTIVE_TAB]}  │  $((SCROLL+1))-${end} of ${total} lines${filter_hint}${logfile_hint}"
    fi
    local keys=" 1-9:Tab  ↑↓/jk:Scroll  PgUp/PgDn  r:Refresh  /:Filter  q:Quit"
    [ "$ACTIVE_TAB" -eq 2 ] && keys=" 1-9:Tab  ↑↓/jk:Scroll  L:LogFile  r:Refresh  /:Filter  q:Quit"
    [ "$ACTIVE_TAB" -eq 5 ] && keys=" 1-9:Tab  ↑↓/jk:Scroll  P:Add Port  r:Refresh  /:Filter  q:Quit"
    _fill_line $((ROWS - 1)) "$BG_BLK$C_CYN" "$keys"
}

# ── Content Rendering ────────────────────────────────────────────────────────

_colorize_line() {
    local line="$1"
    local lower
    lower=$(echo "$line" | tr '[:upper:]' '[:lower:]')

    case "$lower" in
        *"== "*|*"── "*)
            printf "%s %s %s" "$C_BCYN$C_BOLD" "$line" "$C_RESET" ;;
        *"-- "*)
            printf "%s%s%s" "$C_MAG$C_BOLD" "$line" "$C_RESET" ;;
        *"expired"*|*error*|*fail*|*fatal*|*critical*|*"\[fail\]"*|*panic*)
            printf "%s ✗ %s%s" "$C_BRED" "$line" "$C_RESET" ;;
        *warn*)
            printf "%s ⚠ %s%s" "$C_BYEL" "$line" "$C_RESET" ;;
        *running*|*"\[run\]"*|*active*|*" ok "*)
            printf "%s%s%s" "$C_BGRN" "$line" "$C_RESET" ;;
        *"subject:"*|*"issuer:"*|*"valid from:"*|*"expires:"*|*"serial:"*|*"sans:"*)
            printf "%s%s%s" "$C_BCYN" "$line" "$C_RESET" ;;
        *"\[stop\]"*|*inactive*|*dead*)
            printf "%s%s%s" "$C_DIM$C_WHT" "$line" "$C_RESET" ;;
        *"hostname:"*|*"os:"*|*"arch"*|*"cores:"*|*"load"*|*"uptime:"*|*"date:"*|*"users"*|*"total ram"*|*"python:"*)
            printf "%s  ▸ %s%s" "$C_BWHT" "$line" "$C_RESET" ;;
        *"ram:"*|*"swap:"*|*"disk"*)
            printf "%s%s%s" "$C_BMAG" "$line" "$C_RESET" ;;
        *"listen"*|*"established"*)
            printf "%s%s%s" "$C_BGRN" "$line" "$C_RESET" ;;
        *"info"*|*debug*|*"source:"*)
            printf "%s%s%s" "$C_BLU" "$line" "$C_RESET" ;;
        *"press "*|*"usage"*)
            printf "%s%s%s" "$C_BYEL$C_DIM" "$line" "$C_RESET" ;;
        *)
            printf "%s%s%s" "$C_WHT" "$line" "$C_RESET" ;;
    esac
}

_colorize_log_line() {
    local line="$1"
    local lower
    lower=$(echo "$line" | tr '[:upper:]' '[:lower:]')

    # Apply lsee-style keyword highlighting inline
    local result="$line"

    case "$lower" in
        *error*|*fail*|*fatal*|*panic*|*critical*|*emergency*|*alert*)
            result=$(echo "$result" | sed \
                -e "s/[Ee][Rr][Rr][Oo][Rr]/${C_BRED}&${C_RESET}/g" \
                -e "s/[Ff][Aa][Ii][Ll][A-Za-z]*/${C_BRED}&${C_RESET}/g" \
                -e "s/[Ff][Aa][Tt][Aa][Ll]/${C_BRED}&${C_RESET}/g" \
                -e "s/[Pp][Aa][Nn][Ii][Cc]/${C_BRED}&${C_RESET}/g" \
                -e "s/[Cc][Rr][Ii][Tt][Ii][Cc][Aa][Ll]/${C_BRED}&${C_RESET}/g")
            printf "%s" "$result" ;;
        *warn*|*deprecat*)
            result=$(echo "$result" | sed \
                -e "s/[Ww][Aa][Rr][Nn][A-Za-z]*/${C_BYEL}&${C_RESET}/g" \
                -e "s/[Dd][Ee][Pp][Rr][Ee][Cc][Aa][Tt][A-Za-z]*/${C_BYEL}&${C_RESET}/g")
            printf "%s" "$result" ;;
        *removed*|*delet*|*reject*|*denied*|*refused*|*timeout*|*expired*)
            result=$(echo "$result" | sed \
                -e "s/[Rr][Ee][Mm][Oo][Vv][Ee][Dd]/${C_BMAG}&${C_RESET}/g" \
                -e "s/[Dd][Ee][Ll][Ee][Tt][A-Za-z]*/${C_BMAG}&${C_RESET}/g" \
                -e "s/[Rr][Ee][Jj][Ee][Cc][Tt][A-Za-z]*/${C_BMAG}&${C_RESET}/g" \
                -e "s/[Dd][Ee][Nn][Ii][Ee][Dd]/${C_BMAG}&${C_RESET}/g" \
                -e "s/[Rr][Ee][Ff][Uu][Ss][Ee][Dd]/${C_BMAG}&${C_RESET}/g" \
                -e "s/[Tt][Ii][Mm][Ee][Oo][Uu][Tt]/${C_BRED}&${C_RESET}/g" \
                -e "s/[Ee][Xx][Pp][Ii][Rr][Ee][Dd]/${C_BRED}&${C_RESET}/g")
            printf "%s" "$result" ;;
        *connect*|*accept*|*start*|*success*|*running*)
            result=$(echo "$result" | sed \
                -e "s/[Cc][Oo][Nn][Nn][Ee][Cc][Tt][A-Za-z]*/${C_BGRN}&${C_RESET}/g" \
                -e "s/[Aa][Cc][Cc][Ee][Pp][Tt][A-Za-z]*/${C_BGRN}&${C_RESET}/g" \
                -e "s/[Ss][Uu][Cc][Cc][Ee][Ss][Ss]/${C_BGRN}&${C_RESET}/g" \
                -e "s/[Ss][Tt][Aa][Rr][Tt][A-Za-z]*/${C_BCYN}&${C_RESET}/g")
            printf "%s" "$result" ;;
        *info*|*debug*|*notice*)
            printf "%s%s%s" "$C_WHT" "$line" "$C_RESET" ;;
        *)
            printf "%s" "$line" ;;
    esac
}

_draw_content() {
    local visible=$((ROWS - 5))
    local total=${#CONTENT[@]}
    local i y line

    local content_w=$((COLS - 2))  # 1 for left border, 1 for scrollbar
    for ((y=0; y<visible; y++)); do
        i=$((SCROLL + y))
        _goto $((y + 3)) 0

        if [ "$i" -ge "$total" ]; then
            printf "%s %s%-*s" "$C_DIM$BX_V$C_RESET" "" "$((content_w))" ""
            continue
        fi

        line="${CONTENT[$i]}"
        if [ "${#line}" -gt "$((content_w - 1))" ]; then
            line="${line:0:$((content_w - 4))}..."
        fi
        printf "%s %s" "$C_DIM$BX_V$C_RESET" ""
        printf "%-*s" "$((content_w - 1))" ""
        _goto $((y + 3)) 2
        _colorize_line "$line"
    done

    # Scrollbar with gradient style
    if [ "$total" -gt "$visible" ] && [ "$visible" -gt 0 ]; then
        local sb_h=$((visible * visible / total))
        [ "$sb_h" -lt 1 ] && sb_h=1
        local sb_pos=$((SCROLL * visible / total))
        for ((y=0; y<visible; y++)); do
            _goto $((y + 3)) $((COLS - 1))
            if [ "$y" -ge "$sb_pos" ] && [ "$y" -lt "$((sb_pos + sb_h))" ]; then
                printf "%s█%s" "$C_BCYN" "$C_RESET"
            elif [ "$y" -eq "$((sb_pos - 1))" ] || [ "$y" -eq "$((sb_pos + sb_h))" ]; then
                printf "%s▒%s" "$C_CYN" "$C_RESET"
            else
                printf "%s▕%s" "$C_BLK" "$C_RESET"
            fi
        done
    fi
}

# ── Data Collectors ──────────────────────────────────────────────────────────

_collect_system() {
    CONTENT=()
    local fqdn hostname os kernel arch
    fqdn=$(hostname -f 2>/dev/null || hostname)
    hostname=$(hostname -s 2>/dev/null || hostname)
    os=$(uname -s)
    kernel=$(uname -r)
    arch=$(uname -m)

    local ncpu_q
    ncpu_q=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo "?")
    local load_q
    load_q=$(cat /proc/loadavg 2>/dev/null | cut -d' ' -f1 || sysctl -n vm.loadavg 2>/dev/null | awk '{print $2}' || echo "?")
    CONTENT+=("  ${C_BCYN}◈ ${hostname}${C_RESET}  │  ${os} ${arch}  │  ${ncpu_q} cores  │  Load: ${load_q}  │  $(date '+%H:%M:%S')")
    CONTENT+=("")
    CONTENT+=("== ◈ SYSTEM INFORMATION ==")
    CONTENT+=("")
    CONTENT+=("  Hostname:     $fqdn")
    CONTENT+=("  Short Name:   $hostname")
    CONTENT+=("  OS:           $os $kernel")
    CONTENT+=("  Architecture: $arch")
    CONTENT+=("  Python:       $(python3 --version 2>/dev/null | cut -d' ' -f2 || echo 'N/A')")
    CONTENT+=("  Shell:        $SHELL")
    CONTENT+=("  Date:         $(date '+%Y-%m-%d %H:%M:%S %Z')")
    CONTENT+=("")

    local uptime_str
    uptime_str=$(uptime 2>/dev/null)
    CONTENT+=("  Uptime:       $uptime_str")
    CONTENT+=("")

    CONTENT+=("== ⚡ CPU ==")
    CONTENT+=("")
    local ncpu
    ncpu=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo "?")
    CONTENT+=("  Cores:        $ncpu")

    local loadavg
    loadavg=$(cat /proc/loadavg 2>/dev/null || sysctl -n vm.loadavg 2>/dev/null | tr -d '{}')
    [ -n "$loadavg" ] && CONTENT+=("  Load Average: $loadavg")
    CONTENT+=("")

    CONTENT+=("== 🧠 MEMORY ==")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        while IFS= read -r line; do
            case "$line" in
                Mem:*)
                    set -- $line
                    local pct=$(( $3 * 100 / $2 ))
                    local bar_out
                    bar_out=$(_progress_bar $pct 30 "${3}M / ${2}M")
                    CONTENT+=("  RAM:  $bar_out")
                    ;;
                Swap:*)
                    set -- $line
                    local pct=0
                    [ "$2" -gt 0 ] 2>/dev/null && pct=$(( $3 * 100 / $2 ))
                    CONTENT+=("  Swap: ${3}M / ${2}M (${pct}%)")
                    ;;
            esac
        done < <(free -m 2>/dev/null)
    else
        local memsize mem_gb
        memsize=$(sysctl -n hw.memsize 2>/dev/null)
        if [ -n "$memsize" ]; then
            mem_gb=$(( memsize / 1073741824 ))
            local used_pages free_pages page_size used_mb total_mb pct
            page_size=$(sysctl -n hw.pagesize 2>/dev/null || echo 4096)
            # vm_stat gives page counts
            used_pages=$(vm_stat 2>/dev/null | awk '/Pages active/ {gsub(/\./,"",$3); print $3}')
            free_pages=$(vm_stat 2>/dev/null | awk '/Pages free/ {gsub(/\./,"",$3); print $3}')
            if [ -n "$used_pages" ] && [ -n "$free_pages" ]; then
                used_mb=$(( used_pages * page_size / 1048576 ))
                total_mb=$(( memsize / 1048576 ))
                pct=$(( used_mb * 100 / total_mb ))
                local bar_out
                bar_out=$(_progress_bar $pct 30 "${used_mb}M / ${total_mb}M")
                CONTENT+=("  RAM:  $bar_out")
            else
                CONTENT+=("  Total RAM: ${mem_gb} GB")
            fi
        fi
    fi
    CONTENT+=("")

    CONTENT+=("== 💾 DISK ==")
    CONTENT+=("")
    while IFS= read -r line; do
        local pct
        pct=$(echo "$line" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
        if [ -n "$pct" ] && [ "$pct" -gt 90 ] 2>/dev/null; then
            CONTENT+=("  ${C_BRED}$line${C_RESET}")
        elif [ -n "$pct" ] && [ "$pct" -gt 70 ] 2>/dev/null; then
            CONTENT+=("  ${C_BYEL}$line${C_RESET}")
        else
            CONTENT+=("  $line")
        fi
    done < <(df -h / /home /tmp /var 2>/dev/null | sort -u)
    CONTENT+=("")

    CONTENT+=("== 👤 USERS ==")
    CONTENT+=("")
    local nusers
    nusers=$(who 2>/dev/null | wc -l | tr -d ' ')
    CONTENT+=("  Logged in: $nusers")
    while IFS= read -r line; do
        CONTENT+=("  $line")
    done < <(who 2>/dev/null)
}

_collect_services() {
    CONTENT=()
    local os
    os=$(uname -s)

    if [ "$os" = "Linux" ] && command -v systemctl >/dev/null 2>&1; then
        CONTENT+=("== ✅ RUNNING SERVICES ==")
        CONTENT+=("")
        local run_count=0
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_BGRN}●${C_RESET} $name")
            run_count=$((run_count + 1))
        done < <(systemctl list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | head -40)
        CONTENT+=("  ${C_BGRN}── $run_count services running ──${C_RESET}")

        CONTENT+=("")
        CONTENT+=("== ❌ FAILED SERVICES ==")
        CONTENT+=("")
        local has_failed=0
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_BRED}✗${C_RESET} ${C_BRED}$name${C_RESET}")
            has_failed=1
        done < <(systemctl list-units --type=service --state=failed --no-pager --no-legend 2>/dev/null)
        [ $has_failed -eq 0 ] && CONTENT+=("  ${C_BGRN}✓ No failed services${C_RESET}")

        CONTENT+=("")
        CONTENT+=("== ⏹ STOPPED SERVICES ==")
        CONTENT+=("")
        while IFS= read -r line; do
            local name="${line%%.service*}"
            name="${name##* }"
            CONTENT+=("  ${C_DIM}○${C_RESET} ${C_DIM}$name${C_RESET}")
        done < <(systemctl list-units --type=service --state=inactive --no-pager --no-legend 2>/dev/null | head -25)

    elif [ "$os" = "Darwin" ]; then
        CONTENT+=("== LAUNCHCTL SERVICES ==")
        CONTENT+=("")
        while IFS=$'\t' read -r pid status name; do
            if [ "$pid" != "-" ] && [ "$pid" != "PID" ]; then
                CONTENT+=("  ${C_BGRN}●${C_RESET} $name  (PID: $pid)")
            else
                CONTENT+=("  ${C_DIM}○${C_RESET} ${C_DIM}$name${C_RESET}")
            fi
        done < <(launchctl list 2>/dev/null | head -50)
    else
        CONTENT+=("Service listing not supported on this platform")
    fi
}

_collect_logs() {
    CONTENT=()
    local os logfile=""
    os=$(uname -s)

    # Determine log source: custom > maillog > messages > syslog > system.log
    if [ -n "$LOG_FILE" ] && [ -r "$LOG_FILE" ]; then
        logfile="$LOG_FILE"
    elif [ -r /var/log/maillog ]; then
        logfile="/var/log/maillog"
    elif [ -r /var/log/messages ]; then
        logfile="/var/log/messages"
    elif [ -r /var/log/syslog ]; then
        logfile="/var/log/syslog"
    elif [ -r /var/log/system.log ]; then
        logfile="/var/log/system.log"
    fi

    if [ -n "$logfile" ]; then
        local line_count
        line_count=$(wc -l < "$logfile" 2>/dev/null | tr -d ' ')
        CONTENT+=("== 📋 LOG: ${logfile}  (${line_count} lines) ==")
        CONTENT+=("  ${C_DIM}Press ${C_BYEL}L${C_RESET}${C_DIM} to change file  │  ${C_BYEL}R${C_RESET}${C_DIM} to refresh${C_RESET}")
        CONTENT+=("")
        while IFS= read -r line; do
            CONTENT+=("$(_colorize_log_line "$line")")
        done < <(tail -200 "$logfile" 2>/dev/null)
    else
        CONTENT+=("== 📋 SYSTEM LOGS ==")
        CONTENT+=("")
        if [ "$os" = "Linux" ]; then
            while IFS= read -r line; do
                CONTENT+=("$(_colorize_log_line "$line")")
            done < <(journalctl --no-pager -n 100 --output=short 2>/dev/null || echo "No log source available")
        elif [ "$os" = "Darwin" ]; then
            while IFS= read -r line; do
                CONTENT+=("$(_colorize_log_line "$line")")
            done < <(log show --last 1m --style compact 2>/dev/null | tail -50)
        fi
    fi

    CONTENT+=("")
    CONTENT+=("== 📁 AVAILABLE LOG FILES ==")
    CONTENT+=("")
    local lf
    for lf in /var/log/maillog /var/log/messages /var/log/syslog \
               /var/log/auth.log /var/log/secure /var/log/kern.log \
               /var/log/dmesg /var/log/cron /var/log/boot.log \
               /var/log/system.log /var/log/install.log /var/log/wifi.log \
               /var/log/httpd/access_log /var/log/httpd/error_log \
               /var/log/nginx/access.log /var/log/nginx/error.log \
               /var/log/audit/audit.log /var/log/yum.log /var/log/dnf.log; do
        if [ -r "$lf" ]; then
            local sz
            sz=$(du -h "$lf" 2>/dev/null | cut -f1)
            if [ "$lf" = "$logfile" ]; then
                CONTENT+=("  ${C_BCYN}▶${C_RESET} ${C_BCYN}${lf}${C_RESET}  (${sz}) ${C_BGRN}← active${C_RESET}")
            else
                CONTENT+=("  ${C_BGRN}●${C_RESET} $lf  (${sz})")
            fi
        fi
    done
    CONTENT+=("")
    CONTENT+=("  Press ${C_BYEL}L${C_RESET} to enter a log file path for streaming")
}

