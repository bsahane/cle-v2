_check_port_open() {
    local host="$1" port="$2"
    if command -v nc >/dev/null 2>&1; then
        nc -z -w2 "$host" "$port" 2>/dev/null
    elif command -v ncat >/dev/null 2>&1; then
        ncat -z -w2 "$host" "$port" 2>/dev/null
    else
        (echo >/dev/tcp/"$host"/"$port") 2>/dev/null
    fi
}

_get_starttls_flag() {
    local port="$1"
    case "$port" in
        25|587)  echo "-starttls smtp" ;;
        143)     echo "-starttls imap" ;;
        110)     echo "-starttls pop3" ;;
        21)      echo "-starttls ftp" ;;
        *)       echo "" ;;
    esac
}

_collect_certs() {
    CONTENT=()
    local targets=("$@")

    if [ ${#CERT_TARGETS[@]} -gt 0 ]; then
        targets+=("${CERT_TARGETS[@]}")
    fi

    if [ ${#targets[@]} -eq 0 ]; then
        # Priority: SMTP (25 with STARTTLS), then SMTPS (465), then common SSL ports
        if _check_port_open localhost 25; then
            targets+=("localhost:25")
        elif _check_port_open localhost 465; then
            targets+=("localhost:465")
        fi
        local port
        for port in 443 8443 636 993 995; do
            if _check_port_open localhost "$port"; then
                targets+=("localhost:$port")
            fi
        done
        [ ${#targets[@]} -eq 0 ] && targets=("localhost:443")
    fi

    # Deduplicate targets
    local unique=() seen="" t
    for t in "${targets[@]}"; do
        case "$seen" in
            *"|$t|"*) ;;
            *) unique+=("$t"); seen="$seen|$t|" ;;
        esac
    done
    targets=("${unique[@]}")

    CONTENT+=("== 🔒 SSL/TLS CERTIFICATES ==")
    CONTENT+=("  Press ${C_BYEL}P${C_RESET} to add a host:port  │  ${#targets[@]} target(s) configured")
    CONTENT+=("")

    local target host port_s starttls_flag
    for target in "${targets[@]}"; do
        if [[ "$target" != *:* ]]; then
            target="$target:443"
        fi
        host="${target%:*}"
        port_s="${target##*:}"
        starttls_flag=$(_get_starttls_flag "$port_s")

        CONTENT+=("── 🔐 $target ──")
        CONTENT+=("")

        if ! _check_port_open "$host" "$port_s"; then
            CONTENT+=("  ${C_BRED}✗ Port $port_s is not reachable on $host${C_RESET}")
            CONTENT+=("")
            continue
        fi

        local cert_out _timeout_cmd=""
        if command -v timeout >/dev/null 2>&1; then
            _timeout_cmd="timeout 5"
        elif command -v gtimeout >/dev/null 2>&1; then
            _timeout_cmd="gtimeout 5"
        fi
        cert_out=$(${_timeout_cmd} bash -c "echo | openssl s_client -connect '$target' -servername '$host' $starttls_flag 2>/dev/null" | openssl x509 -noout -subject -issuer -dates -serial -ext subjectAltName 2>/dev/null)
        if [ -n "$cert_out" ]; then
            while IFS= read -r line; do
                case "$line" in
                    *subject*) CONTENT+=("  ${C_BCYN}Subject:${C_RESET}    ${line#*= }") ;;
                    *issuer*)  CONTENT+=("  ${C_BCYN}Issuer:${C_RESET}     ${line#*= }") ;;
                    *notBefore*) CONTENT+=("  ${C_BCYN}Valid From:${C_RESET} ${line#*=}") ;;
                    *notAfter*)
                        local expiry="${line#*=}"
                        local now_epoch exp_epoch days_left
                        now_epoch=$(date +%s)
                        exp_epoch=$(date -d "$expiry" +%s 2>/dev/null || date -j -f "%b %d %T %Y %Z" "$expiry" +%s 2>/dev/null || echo 0)
                        if [ "$exp_epoch" -gt 0 ] 2>/dev/null; then
                            days_left=$(( (exp_epoch - now_epoch) / 86400 ))
                            if [ "$days_left" -lt 0 ]; then
                                CONTENT+=("  ${C_BRED}Expires:${C_RESET}    $expiry ${C_BRED}⚠ EXPIRED!${C_RESET}")
                            elif [ "$days_left" -lt 30 ]; then
                                CONTENT+=("  ${C_BYEL}Expires:${C_RESET}    $expiry ${C_BYEL}⚠ ${days_left}d left${C_RESET}")
                            else
                                CONTENT+=("  ${C_BGRN}Expires:${C_RESET}    $expiry ${C_BGRN}✓ ${days_left}d left${C_RESET}")
                            fi
                        else
                            CONTENT+=("  ${C_BCYN}Expires:${C_RESET}    $expiry")
                        fi
                        ;;
                    *serial*)  CONTENT+=("  ${C_BCYN}Serial:${C_RESET}     ${line#*=}") ;;
                    *DNS:*|*IP:*)
                        CONTENT+=("  ${C_BCYN}SANs:${C_RESET}")
                        local san_entry
                        local san_list
                        san_list=$(echo "$line" | tr ',' '\n')
                        while IFS= read -r san_entry; do
                            san_entry=$(echo "$san_entry" | sed 's/^[[:space:]]*//')
                            [ -z "$san_entry" ] && continue
                            case "$san_entry" in
                                DNS:*) CONTENT+=("    ${C_BGRN}◦${C_RESET} ${san_entry#DNS:}") ;;
                                IP:*)  CONTENT+=("    ${C_BYEL}◦${C_RESET} ${san_entry}") ;;
                                othername:*) CONTENT+=("    ${C_DIM}◦ ${san_entry}${C_RESET}") ;;
                                *) CONTENT+=("    ${C_DIM}◦ ${san_entry}${C_RESET}") ;;
                            esac
                        done <<< "$san_list"
                        ;;
                esac
            done <<< "$cert_out"
        else
            if [ -n "$starttls_flag" ]; then
                CONTENT+=("  ${C_BYEL}⚠ No SSL certificate (STARTTLS attempted for port $port_s)${C_RESET}")
            else
                CONTENT+=("  ${C_BYEL}⚠ No SSL certificate on this port${C_RESET}")
            fi
        fi
        CONTENT+=("")
    done
}

_collect_storage() {
    CONTENT=()
    local os
    os=$(uname -s)

    CONTENT+=("== 💾 FILESYSTEM USAGE ==")
    CONTENT+=("")
    while IFS= read -r line; do
        # Colorize usage percentage
        local pct
        pct=$(echo "$line" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
        if [ -n "$pct" ] && [ "$pct" -gt 90 ] 2>/dev/null; then
            CONTENT+=("${C_BRED}$line${C_RESET}")
        elif [ -n "$pct" ] && [ "$pct" -gt 70 ] 2>/dev/null; then
            CONTENT+=("${C_BYEL}$line${C_RESET}")
        else
            CONTENT+=("  $line")
        fi
    done < <(df -h 2>/dev/null)

    CONTENT+=("")
    CONTENT+=("== 📁 MOUNT POINTS ==")
    CONTENT+=("")
    while IFS= read -r line; do
        CONTENT+=("  ${line:0:120}")
    done < <(mount 2>/dev/null | head -20)

    if [ "$os" = "Linux" ] && command -v lsblk >/dev/null 2>&1; then
        CONTENT+=("")
        CONTENT+=("== BLOCK DEVICES ==")
        CONTENT+=("")
        while IFS= read -r line; do
            CONTENT+=("  $line")
        done < <(lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null | head -20)
    fi
}

_collect_security() {
    CONTENT=()
    local os
    os=$(uname -s)

    CONTENT+=("== 🛡 SECURITY OVERVIEW ==")
    CONTENT+=("")

    # SELinux status (Linux)
    if [ "$os" = "Linux" ]; then
        if command -v getenforce >/dev/null 2>&1; then
            local se_status
            se_status=$(getenforce 2>/dev/null)
            case "$se_status" in
                Enforcing) CONTENT+=("  ${C_BGRN}●${C_RESET} SELinux: ${C_BGRN}Enforcing${C_RESET}") ;;
                Permissive) CONTENT+=("  ${C_BYEL}●${C_RESET} SELinux: ${C_BYEL}Permissive${C_RESET}") ;;
                *) CONTENT+=("  ${C_BRED}●${C_RESET} SELinux: ${C_BRED}${se_status:-Disabled}${C_RESET}") ;;
            esac
        else
            CONTENT+=("  ${C_DIM}SELinux: not installed${C_RESET}")
        fi
        CONTENT+=("")
    fi

    # Firewall status
    CONTENT+=("── 🔥 Firewall ──")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        if command -v firewall-cmd >/dev/null 2>&1; then
            local fw_state
            fw_state=$(firewall-cmd --state 2>/dev/null)
            if [ "$fw_state" = "running" ]; then
                CONTENT+=("  ${C_BGRN}●${C_RESET} firewalld: running")
                local zone
                zone=$(firewall-cmd --get-default-zone 2>/dev/null)
                CONTENT+=("  Default zone: $zone")
                CONTENT+=("")
                CONTENT+=("  Active rules:")
                while IFS= read -r line; do
                    CONTENT+=("    $line")
                done < <(firewall-cmd --list-all 2>/dev/null | head -15)
            else
                CONTENT+=("  ${C_BRED}●${C_RESET} firewalld: ${fw_state:-not running}")
            fi
        elif command -v iptables >/dev/null 2>&1; then
            local rules
            rules=$(iptables -L -n 2>/dev/null | wc -l | tr -d ' ')
            CONTENT+=("  iptables: $rules rules")
            while IFS= read -r line; do
                CONTENT+=("    $line")
            done < <(iptables -L -n 2>/dev/null | head -20)
        elif command -v ufw >/dev/null 2>&1; then
            while IFS= read -r line; do
                CONTENT+=("  $line")
            done < <(ufw status 2>/dev/null | head -15)
        fi
    elif [ "$os" = "Darwin" ]; then
        local pf_status
        pf_status=$(/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null)
        if echo "$pf_status" | grep -qi "enabled"; then
            CONTENT+=("  ${C_BGRN}●${C_RESET} macOS Firewall: enabled")
        else
            CONTENT+=("  ${C_BYEL}●${C_RESET} macOS Firewall: ${pf_status:-unknown}")
        fi
    fi
    CONTENT+=("")

    # Failed SSH logins
    CONTENT+=("── 🔑 Recent Failed Logins ──")
    CONTENT+=("")
    if [ "$os" = "Linux" ]; then
        local fail_count=0
        while IFS= read -r line; do
            CONTENT+=("  ${C_BYEL}⚠${C_RESET} $line")
            fail_count=$((fail_count + 1))
        done < <(journalctl -u sshd --no-pager -n 50 2>/dev/null | grep -i "failed\|invalid" | tail -15)
        if [ $fail_count -eq 0 ]; then
            while IFS= read -r line; do
                CONTENT+=("  ${C_BYEL}⚠${C_RESET} $line")
                fail_count=$((fail_count + 1))
            done < <(grep -i "failed\|invalid" /var/log/secure 2>/dev/null | tail -15)
        fi
        [ $fail_count -eq 0 ] && CONTENT+=("  ${C_BGRN}✓ No recent failed logins${C_RESET}")
    elif [ "$os" = "Darwin" ]; then
        local fail_count=0
        while IFS= read -r line; do
            CONTENT+=("  ${C_BYEL}⚠${C_RESET} $line")
            fail_count=$((fail_count + 1))
        done < <(last -5 2>/dev/null | grep -v "^$" | head -10)
        [ $fail_count -eq 0 ] && CONTENT+=("  ${C_DIM}No login data available${C_RESET}")
    fi
    CONTENT+=("")

    # Last successful logins
    CONTENT+=("── 👤 Recent Logins ──")
    CONTENT+=("")
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        CONTENT+=("  $line")
    done < <(last -10 2>/dev/null | head -10)
    CONTENT+=("")

    # Open SUID/SGID files (security audit)
    if [ "$os" = "Linux" ]; then
        CONTENT+=("── 📝 Sudoers ──")
        CONTENT+=("")
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            case "$line" in
                \#*) ;;
                *) CONTENT+=("  $line") ;;
            esac
        done < <(cat /etc/sudoers 2>/dev/null | grep -v '^#' | grep -v '^$' | head -15)
    fi
}

_collect_terminal() {
    CONTENT=()
    local os
    os=$(uname -s)

    # tmux sessions
    CONTENT+=("== 🖥 TMUX SESSIONS ==")
    CONTENT+=("")
    if command -v tmux >/dev/null 2>&1; then
        local tmux_count=0
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            local sess_name="${line%%:*}"
            local rest="${line#*:}"
            local attached=""
            [[ "$line" == *"(attached)"* ]] && attached=" ${C_BGRN}← attached${C_RESET}"
            CONTENT+=("  ${C_BCYN}●${C_RESET} ${C_BOLD}${sess_name}${C_RESET} ${rest}${attached}")
            tmux_count=$((tmux_count + 1))
        done < <(tmux list-sessions 2>/dev/null)

        if [ $tmux_count -gt 0 ]; then
            CONTENT+=("")
            CONTENT+=("  ${C_DIM}── Windows ──${C_RESET}")
            CONTENT+=("")
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                local active=""
                [[ "$line" == *"(active)"* ]] && active="${C_BGRN} ← active${C_RESET}"
                CONTENT+=("    ${C_WHT}$line${C_RESET}${active}")
            done < <(tmux list-windows -a 2>/dev/null)
        else
            CONTENT+=("  ${C_DIM}No tmux sessions running${C_RESET}")
        fi
    else
        CONTENT+=("  ${C_DIM}tmux not installed${C_RESET}")
    fi
    CONTENT+=("")

    # screen sessions
    CONTENT+=("== 📺 SCREEN SESSIONS ==")
    CONTENT+=("")
    if command -v screen >/dev/null 2>&1; then
        local screen_count=0
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            case "$line" in
                *Attached*) CONTENT+=("  ${C_BGRN}●${C_RESET} $line"); screen_count=$((screen_count + 1)) ;;
                *Detached*) CONTENT+=("  ${C_BYEL}○${C_RESET} $line"); screen_count=$((screen_count + 1)) ;;
                *) ;;
            esac
        done < <(screen -ls 2>/dev/null)
        [ $screen_count -eq 0 ] && CONTENT+=("  ${C_DIM}No screen sessions running${C_RESET}")
    else
        CONTENT+=("  ${C_DIM}screen not installed${C_RESET}")
    fi
    CONTENT+=("")

    # Active TTY/PTY sessions
    CONTENT+=("== 📟 ACTIVE TERMINALS ==")
    CONTENT+=("")
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        CONTENT+=("  $line")
    done < <(who 2>/dev/null)
    CONTENT+=("")

    # Shell processes
    CONTENT+=("== 🐚 SHELL PROCESSES ==")
    CONTENT+=("")
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        CONTENT+=("  $line")
    done < <(ps aux 2>/dev/null | grep -E '[b]ash|[z]sh|[f]ish|[s]h ' | head -20)
    CONTENT+=("")

    # Terminal info
    CONTENT+=("== ⓘ CURRENT TERMINAL ==")
    CONTENT+=("")
    CONTENT+=("  TERM:     ${TERM:-unknown}")
    CONTENT+=("  TTY:      $(tty 2>/dev/null || echo 'N/A')")
    CONTENT+=("  Size:     ${COLS}x${ROWS}")
    CONTENT+=("  Colors:   $(tput colors 2>/dev/null || echo '?')")
    CONTENT+=("  Shell:    ${SHELL:-unknown}")
    CONTENT+=("  PID:      $$")
    [ -n "${TMUX:-}" ] && CONTENT+=("  In tmux:  ${C_BGRN}yes${C_RESET}")
    [ -n "${STY:-}" ] && CONTENT+=("  In screen: ${C_BGRN}yes${C_RESET}")
    [ -n "${SSH_CONNECTION:-}" ] && CONTENT+=("  SSH from: ${SSH_CONNECTION%% *}")
}

# ── Log File Selector ────────────────────────────────────────────────────────

_select_logfile() {
    local input=""
    _fill_line $((ROWS - 2)) "$BG_GRN$C_BLK$C_BOLD" \
        " Enter log file path (Enter=confirm, Esc=cancel, empty=system logs): "

    # Simple inline text input
    tput cnorm 2>/dev/null
    while true; do
        _fill_line $((ROWS - 3)) "$BG_BLK$C_BWHT" " > ${input}▌"
        IFS= read -rsn1 ch 2>/dev/null
        case "$ch" in
            $'\e')
                tput civis 2>/dev/null
                return ;;
            "") # Enter
                LOG_FILE="$input"
                SCROLL=0
                tput civis 2>/dev/null
                return ;;
            $'\177'|$'\b') input="${input%?}" ;;
            *)
                if [ ${#ch} -eq 1 ] && [ "$(printf '%d' "'$ch")" -ge 32 ] 2>/dev/null; then
                    input+="$ch"
                fi
                ;;
        esac
    done
}

_select_cert_target() {
    local input=""
    _fill_line $((ROWS - 2)) "$BG_MAG$C_BWHT$C_BOLD" \
        " 🔒 Enter host:port (e.g. google.com:443). Enter=confirm, Esc=cancel: "

    tput cnorm 2>/dev/null
    while true; do
        _fill_line $((ROWS - 3)) "$BG_BLK$C_BWHT" " > ${input}▌"
        IFS= read -rsn1 ch 2>/dev/null
        case "$ch" in
            $'\e')
                tput civis 2>/dev/null
                return ;;
            "")
                if [ -n "$input" ]; then
                    [[ "$input" != *:* ]] && input="$input:443"
                    CERT_TARGETS+=("$input")
                fi
                SCROLL=0
                tput civis 2>/dev/null
                return ;;
            $'\177'|$'\b') input="${input%?}" ;;
            *)
                if [ ${#ch} -eq 1 ] && [ "$(printf '%d' "'$ch")" -ge 32 ] 2>/dev/null; then
                    input+="$ch"
                fi
                ;;
        esac
    done
}

# ── Content Filtering ────────────────────────────────────────────────────────

_filter_content() {
    if [ -z "$FILTER" ]; then
        return
    fi
    local filtered=() line lower_filter lower_line
    lower_filter=$(echo "$FILTER" | tr '[:upper:]' '[:lower:]')
    for line in "${CONTENT[@]}"; do
        lower_line=$(echo "$line" | tr '[:upper:]' '[:lower:]')
        if [[ "$lower_line" == *"$lower_filter"* ]]; then
            filtered+=("$line")
        fi
    done
    CONTENT=("${filtered[@]}")
}

# ── Tab Data Loading ─────────────────────────────────────────────────────────

_show_loading() {
    local center_row=$(( (ROWS - 3) / 2 + 3 ))
    local msg="  ⟳  Loading ${TABS[$ACTIVE_TAB]}...  "
    local center_col=$(( (COLS - ${#msg}) / 2 ))
    [ $center_col -lt 0 ] && center_col=2
    _goto $center_row $center_col
    printf "%s%s%s" "$BG_BLU$C_BWHT$C_BOLD" "$msg" "$C_RESET"
}

_load_tab() {
    local force=${FORCE_REFRESH:-0}
    local now
    now=$(date +%s)
    local cached_time=${TAB_CACHE_TIME[$ACTIVE_TAB]:-0}

    # Use cache if data is less than 15 seconds old (unless forced)
    if [ "$force" -eq 0 ] && [ "$((now - cached_time))" -lt 15 ] && [ -n "${TAB_CACHE[$ACTIVE_TAB]:-}" ]; then
        IFS=$'\x01' read -ra CONTENT <<< "${TAB_CACHE[$ACTIVE_TAB]}"
        [ -n "$FILTER" ] && _filter_content
        return
    fi

    _show_loading

    case "$ACTIVE_TAB" in
        0) _collect_system ;;
        1) _collect_services ;;
        2) _collect_logs ;;
        3) _collect_network ;;
        4) _collect_processes ;;
        5) _collect_certs "$@" ;;
        6) _collect_storage ;;
        7) _collect_security ;;
        8) _collect_terminal ;;
    esac

    # Store in cache
    local IFS=$'\x01'
    TAB_CACHE[$ACTIVE_TAB]="${CONTENT[*]}"
    TAB_CACHE_TIME[$ACTIVE_TAB]=$now

    [ -n "$FILTER" ] && _filter_content
}

# ── Input Handling ───────────────────────────────────────────────────────────

_handle_input() {
    local key="" escape_seq=""
    IFS= read -rsn1 key 2>/dev/null || return 1

    # Handle escape sequences
    if [ "$key" = $'\e' ]; then
        IFS= read -rsn1 -t 0.1 key2 2>/dev/null
        if [ "$key2" = "[" ]; then
            IFS= read -rsn1 -t 0.1 key3 2>/dev/null
            case "$key3" in
                A) key="UP" ;;     # Up arrow
                B) key="DOWN" ;;   # Down arrow
                C) key="RIGHT" ;;
                D) key="LEFT" ;;
                5) IFS= read -rsn1 -t 0.1 _ 2>/dev/null; key="PGUP" ;;
                6) IFS= read -rsn1 -t 0.1 _ 2>/dev/null; key="PGDN" ;;
                H) key="HOME" ;;
                F) key="END" ;;
                Z) key="BTAB" ;;   # Shift-Tab
            esac
        elif [ -z "$key2" ]; then
            if [ "$FILTERING" -eq 1 ]; then
                FILTERING=0
                FILTER=""
                SCROLL=0
                return 0
            fi
        fi
    fi

    local visible=$((ROWS - 5))
    local total=${#CONTENT[@]}

    # Filter mode
    if [ "$FILTERING" -eq 1 ]; then
        case "$key" in
            "") # Enter
                FILTERING=0
                SCROLL=0
                _load_tab "$@"
                ;;
            $'\177'|$'\b') # Backspace
                FILTER="${FILTER%?}"
                ;;
            *)
                if [ ${#key} -eq 1 ] && [ "$(printf '%d' "'$key")" -ge 32 ] 2>/dev/null; then
                    FILTER+="$key"
                fi
                ;;
        esac
        return 0
    fi

    case "$key" in
        q|Q) return 1 ;;
        /) FILTERING=1; FILTER="" ;;
        l|L)
            if [ "$ACTIVE_TAB" -eq 2 ]; then
                _select_logfile
                FORCE_REFRESH=1
                _load_tab "$@"
                FORCE_REFRESH=0
            fi
            ;;
        p|P)
            if [ "$ACTIVE_TAB" -eq 5 ]; then
                _select_cert_target
                FORCE_REFRESH=1
                _load_tab "$@"
                FORCE_REFRESH=0
            fi
            ;;
        r|R)
            SCROLL=0
            FORCE_REFRESH=1
            _load_tab "$@"
            FORCE_REFRESH=0
            ;;
        UP|k) [ "$SCROLL" -gt 0 ] && SCROLL=$((SCROLL - 1)) ;;
        DOWN|j) [ "$SCROLL" -lt "$((total - visible))" ] 2>/dev/null && SCROLL=$((SCROLL + 1)) ;;
        PGUP) SCROLL=$((SCROLL - visible)); [ "$SCROLL" -lt 0 ] && SCROLL=0 ;;
        PGDN)
            SCROLL=$((SCROLL + visible))
            local max=$((total - visible))
            [ "$max" -lt 0 ] && max=0
            [ "$SCROLL" -gt "$max" ] && SCROLL=$max
            ;;
        HOME|g) SCROLL=0 ;;
        END|G) SCROLL=$((total - visible)); [ "$SCROLL" -lt 0 ] && SCROLL=0 ;;
        $'\t') # Tab
            ACTIVE_TAB=$(( (ACTIVE_TAB + 1) % ${#TABS[@]} ))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
        BTAB) # Shift-Tab
            ACTIVE_TAB=$(( (ACTIVE_TAB - 1 + ${#TABS[@]}) % ${#TABS[@]} ))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
        [1-9])
            ACTIVE_TAB=$((key - 1))
            SCROLL=0
            FILTER=""
            _load_tab "$@"
            ;;
    esac
    return 0
}

# ── Main Loop ────────────────────────────────────────────────────────────────

main() {
    _tui_init
    _clear

    local cert_targets=("$@")
    FORCE_REFRESH=1
    _load_tab "${cert_targets[@]}"
    FORCE_REFRESH=0

    local last_refresh
    last_refresh=$(date +%s)

    while true; do
        # Handle terminal resize
        local new_cols new_rows
        new_cols=$(tput cols)
        new_rows=$(tput lines)
        if [ "$new_cols" != "$COLS" ] || [ "$new_rows" != "$ROWS" ]; then
            COLS=$new_cols
            ROWS=$new_rows
            _clear
        fi

        _draw_tabs
        _draw_content
        _draw_status

        if ! _handle_input "${cert_targets[@]}"; then
            break
        fi

        # Auto-refresh every 30 seconds (cache handles 15s dedup)
        local now
        now=$(date +%s)
        if [ $((now - last_refresh)) -ge 30 ]; then
            FORCE_REFRESH=1
            _load_tab "${cert_targets[@]}"
            FORCE_REFRESH=0
            last_refresh=$now
        fi
    done
}

main "$@"
